# ========== FULL WORKING VERSION ==========
%matplotlib inline
%config InlineBackend.figure_format = 'retina'
import sympy as sp
from control import tf, step_response, poles, zeros, pzmap
import matplotlib.pyplot as plt
import numpy as np
plt.rcParams['figure.figsize'] = [12, 8]

# Your original code with PLOT FIXES
s, X, Y = sp.symbols('s X Y')
A = 2*s**2 * Y + s * Y
B = s * X + X

tf_expr = sp.solve(sp.Eq(A, B), Y)[0] / X
tf_simp = sp.simplify(tf_expr)
print(f"G(s) = {tf_simp}")

# Convert to control format
num = [float(c) for c in sp.Poly(sp.numer(tf_simp), s).all_coeffs()]
den = [float(c) for c in sp.Poly(sp.denom(tf_simp), s).all_coeffs()]
sys = tf(num, den)
print(sys)

print(f"Poles: {poles(sys)}")
print(f"Zeros: {zeros(sys)}")

# ========== STEP RESPONSE - FIXED ==========
print("\n📈 PLOTTING...")
t = np.linspace(0, 20, 1000)
t_out, y_out = step_response(sys, T=t)

plt.figure(figsize=(12, 6))
plt.plot(t_out, y_out, 'b-', linewidth=3, label='Step Response')
plt.title('Step Response: 2ÿ + ẏ = ẋ + x', fontsize=16, fontweight='bold')
plt.xlabel('Time (s)', fontsize=14)
plt.ylabel('y(t)', fontsize=14)
plt.grid(True, alpha=0.3)
plt.legend(fontsize=12)
plt.tight_layout()
plt.show()  # ← CRITICAL

# ========== POLE-ZERO MAP - FIXED ==========
plt.figure(figsize=(10, 8))
pzmap(sys, grid=True)
plt.title('Pole-Zero Map', fontsize=16, fontweight='bold')
plt.grid(True)
plt.tight_layout()
plt.show()  # ← CRITICAL
print("✅ PLOTS COMPLETE!")
