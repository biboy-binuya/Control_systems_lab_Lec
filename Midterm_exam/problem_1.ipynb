import control as ctrl
import numpy as np
import matplotlib.pyplot as plt

# ===============================
# Step 1: Define the Transfer Function
# ===============================
# Numerator: s + 1 -> coefficients [1, 1]
# Denominator: s^4 + 4s^3 + 7s^2 + 6s + 3 -> coefficients [1, 4, 7, 6, 3]
numerator = [1, 1]
denominator = [1, 4, 7, 6, 3]

G = ctrl.TransferFunction(numerator, denominator)

print("Transfer Function:")
print(f"G(s) = {G}")

# ===============================
# Step 2: Compute Poles and Zeros
# ===============================
poles = ctrl.poles(G)
zeros = ctrl.zeros(G)

print(f"Poles: {poles}")
print(f"Zeros: {zeros}")

# ===============================
# Step 3: Step Response Plot
# ===============================
t, y = ctrl.step_response(G)

plt.figure(figsize=(10, 5))
plt.plot(t, y, color='#0D9488', linewidth=2, label='Step Response')
plt.title('Step Response of the System', fontsize=14, fontweight='bold')
plt.xlabel('Time (s)', fontsize=12)
plt.ylabel('Output', fontsize=12)
plt.grid(True, linestyle='--', alpha=0.7)
plt.legend()
plt.tight_layout()
plt.show()

# ===============================
# Step 4: Pole-Zero Map
# ===============================
plt.figure(figsize=(6, 6))
ctrl.pzmap(G, grid=True, plot=True)
plt.title('Pole-Zero Map', fontsize=14, fontweight='bold')
plt.tight_layout()
plt.show()
